# RP_ORIGIN must exactly match window.location.origin in the browser
WEBAUTHN_RP_ORIGIN=http://localhost:5173

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Used for receipt emails AND scheduled reports.
# Leave SMTP_HOST blank to disable all email sending.
# Resend SMTP bridge: host=smtp.resend.com port=587 user=resend pass=<API_KEY>
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
SMTP_PASS=re_bdpmESyj_DjxmBWniHQWYeLQNmBoHoqfr
SMTP_FROM=POS System <onboarding@resend.dev>

# ── Scheduled Reports ─────────────────────────────────────────────────────────
# Reports are sent to all Admin users that have an email address in the DB.
# Set DISABLE_CRON=true in worker-less environments (e.g. serverless functions).
DISABLE_CRON=false

# ── Staffing Betit (EMS) Integration ─────────────────────────────────────────
# POS backend calls EMS to pull employee shift/schedule data.
# STAFFING_API_URL: base URL of the EMS API (no trailing slash)
# STAFFING_API_TOKEN: shared secret — must match STAFFING_API_TOKEN on EMS server
STAFFING_API_URL=http://localhost:5002/api
STAFFING_API_TOKEN=dummy_staffing_api_token_for_local_development_only

# ── URLs ───────────────────────────────────────────────────────────────────────
# Used to build email verification links. Update both for production.
BACKEND_URL=http://localhost:5001
FRONTEND_URL=http://localhost:5173
